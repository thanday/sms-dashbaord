<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hadhiyaa Badhiyaa | SSTV</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #02040a; color: #94a3b8; }
        .glass { background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.03); }
        .day-header:hover { background: rgba(59, 130, 246, 0.1); }
        .collapsed-content { display: none; }
        input::placeholder { color: #475569; }
        .status-pill { font-size: 9px; font-weight: 800; letter-spacing: 0.05em; }
    </style>
</head>
<body class="p-4 md:p-10">
    <div class="max-w-6xl mx-auto">
        
        <div class="flex justify-between items-center mb-10">
            <div>
                <h1 class="text-4xl font-black text-white tracking-tighter uppercase italic">Hadhiyaa Badhiyaa</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span class="h-1.5 w-1.5 bg-blue-500 rounded-full animate-pulse"></span>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">SSTV Program Management</p>
                </div>
            </div>
            <div class="flex items-center gap-4 glass px-6 py-3 rounded-2xl">
                <div class="text-right">
                    <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Operator</p>
                    <p class="text-white text-xs font-bold uppercase"><%= role %></p>
                </div>
                <div class="h-8 w-[1px] bg-white/10 mx-2"></div>
                <a href="/logout" class="text-slate-400 hover:text-white transition-colors">
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                </a>
            </div>
        </div>

        <% if (role === 'admin') { %>
        <div class="glass p-8 rounded-[2rem] mb-10 shadow-2xl">
            <h2 class="text-xs font-black text-blue-500 uppercase tracking-[0.3em] mb-6 flex items-center gap-2">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z"/></svg>
                Register New Winner
            </h2>
            <form id="giftForm" class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div>
                    <label class="text-[9px] font-black text-slate-500 uppercase ml-2 mb-1 block">Full Name</label>
                    <input type="text" id="name" placeholder="Name" required class="w-full bg-black/40 border border-white/5 rounded-xl px-5 py-3.5 text-white focus:border-blue-500 outline-none transition-all">
                </div>
                <div>
                    <label class="text-[9px] font-black text-slate-500 uppercase ml-2 mb-1 block">Phone</label>
                    <input type="text" id="phone" placeholder="7xxxxxx" required class="w-full bg-black/40 border border-white/5 rounded-xl px-5 py-3.5 text-white focus:border-blue-500 outline-none transition-all">
                </div>
                <div>
                    <label class="text-[9px] font-black text-slate-500 uppercase ml-2 mb-1 block">Age</label>
                    <input type="number" id="age" placeholder="00" required class="w-full bg-black/40 border border-white/5 rounded-xl px-5 py-3.5 text-white focus:border-blue-500 outline-none transition-all">
                </div>
                <div>
                    <label class="text-[9px] font-black text-slate-500 uppercase ml-2 mb-1 block">Program Day</label>
                    <input type="number" id="day" placeholder="Day #" required class="w-full bg-black/40 border border-white/5 rounded-xl px-5 py-3.5 text-white focus:border-blue-500 outline-none transition-all">
                </div>
                <button type="submit" class="md:col-span-4 bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl uppercase tracking-widest transition-all shadow-lg shadow-blue-900/20">Save Entry</button>
            </form>
        </div>
        <% } %>

        <div class="flex flex-col gap-4" id="daysContainer">
            </div>
    </div>

    <script>
        const userRole = "<%= role %>";

        async function loadGifts() {
            const res = await fetch('/api/gifts');
            const data = await res.json();
            const container = document.getElementById('daysContainer');
            
            // Group data by day
            const grouped = data.reduce((acc, obj) => {
                const day = obj.day_number;
                if (!acc[day]) acc[day] = [];
                acc[day].push(obj);
                return acc;
            }, {});

            // Sort days descending
            const sortedDays = Object.keys(grouped).sort((a, b) => b - a);

            container.innerHTML = sortedDays.map(day => `
                <div class="glass rounded-3xl overflow-hidden mb-2">
                    <button onclick="toggleDay(${day})" class="day-header w-full p-6 flex justify-between items-center transition-all">
                        <div class="flex items-center gap-4">
                            <span class="bg-blue-600/20 text-blue-500 px-4 py-1.5 rounded-full text-[10px] font-black uppercase">Day ${day}</span>
                            <span class="text-slate-500 text-[10px] font-bold uppercase tracking-widest">${grouped[day].length} Winners</span>
                        </div>
                        <svg id="icon-${day}" class="text-slate-600 transition-transform duration-300" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    
                    <div id="content-${day}" class="collapsed-content border-t border-white/5 bg-black/20 overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="text-[9px] font-black text-slate-600 uppercase tracking-[0.2em] border-b border-white/5">
                                <tr>
                                    <th class="px-8 py-4">Participant</th>
                                    <th class="px-8 py-4">Marketing Comments</th>
                                    <th class="px-8 py-4">Status</th>
                                    ${userRole === 'admin' ? '<th class="px-8 py-4 text-right">Action</th>' : ''}
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                ${grouped[day].map(g => `
                                    <tr class="group hover:bg-white/[0.02]">
                                        <td class="px-8 py-6">
                                            <div class="flex flex-col">
                                                <span class="text-white font-bold text-base">${g.participant_name}</span>
                                                <span class="text-blue-500/70 text-[11px] font-mono mt-0.5">${g.phone_number} (Age: ${g.age})</span>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6">
                                            <input type="text" value="${g.marketing_comments || ''}" 
                                                onblur="updateMarketing(${g.id}, 'comments', this.value)"
                                                placeholder="Add notes..."
                                                class="bg-transparent border-b border-transparent hover:border-slate-800 focus:border-blue-500 outline-none text-xs text-slate-400 w-full transition-all italic">
                                        </td>
                                        <td class="px-8 py-6">
                                            <select onchange="updateMarketing(${g.id}, 'status', this.value)"
                                                class="bg-black/40 border border-white/10 rounded-lg px-3 py-1.5 status-pill uppercase outline-none ${g.status === 'Pending' ? 'text-amber-500' : 'text-green-500'} ">
                                                <option value="Pending" ${g.status === 'Pending' ? 'selected' : ''}>Pending</option>
                                                <option value="Handover Completed" ${g.status === 'Handover Completed' ? 'selected' : ''}>Delivered</option>
                                                <option value="Gift Cancelled" ${g.status === 'Cancel' ? 'selected' : ''}>Cancel</option>

                                            </select>
                                        </td>
                                        ${userRole === 'admin' ? `
                                        <td class="px-8 py-6 text-right">
                                            <button onclick="deleteRecord(${g.id})" class="text-slate-700 hover:text-red-500 transition-colors">
                                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                            </button>
                                        </td>` : ''}
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            `).join('');
        }

        function toggleDay(day) {
            const content = document.getElementById(`content-${day}`);
            const icon = document.getElementById(`icon-${day}`);
            const isOpen = content.style.display === "block";
            
            content.style.display = isOpen ? "none" : "block";
            icon.style.transform = isOpen ? "rotate(0deg)" : "rotate(180deg)";
        }

        document.getElementById('giftForm').onsubmit = async (e) => {
            e.preventDefault();
            const phone = document.getElementById('phone').value;
            const day = document.getElementById('day').value;
            
            const checkRes = await fetch(`/api/gifts/check/${phone}`);
            const checkData = await checkRes.json();
            
            if(checkData.exists) {
                if(!confirm(`⚠️ DUPLICATE DETECTED: This number already won on DAY ${checkData.day}. Proceed with adding for Day ${day}?`)) return;
            }

            const payload = {
                name: document.getElementById('name').value,
                phone: phone,
                age: document.getElementById('age').value,
                day: day,
                comments: '', 
                status: 'Pending'
            };

            const res = await fetch('/api/gifts', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            });
            
            if(res.ok) {
                document.getElementById('giftForm').reset();
                loadGifts();
            }
        };

        async function updateMarketing(id, field, value) {
            await fetch(`/api/gifts/update/${id}`, {
                method: 'PUT',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ field, value })
            });
        }

        async function deleteRecord(id) {
            if(!confirm("Permanently delete this winner?")) return;
            await fetch(`/api/gifts/${id}`, { method: 'DELETE' });
            loadGifts();
        }

        loadGifts();
    </script>
</body>
</html>