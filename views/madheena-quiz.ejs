<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Madheena Quiz | SSTV Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: #02040a;
        color: #94a3b8;
      }
      .glass {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.03);
      }
      .answer-badge {
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #1e293b;
        border-radius: 10px;
      }
    </style>
  </head>
  <body class="p-6 md:p-12">
    <div class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6"
      >
        <div>
          <h1
            class="text-5xl font-black text-white tracking-tighter uppercase italic leading-none"
          >
            Madheena Quiz
          </h1>
          <p
            class="text-emerald-500 font-bold text-[10px] uppercase tracking-[0.4em] mt-3 flex items-center gap-2"
          >
            <span class="w-8 h-[1px] bg-emerald-500"></span> 30 Days Ramadan
            Analytics
          </p>
        </div>
        <div class="flex gap-4">
          <button
            onclick="exportToTxt()"
            class="glass px-6 py-3 rounded-2xl text-white text-[10px] font-black uppercase tracking-widest hover:bg-white/5 transition-all border border-white/10"
          >
            Export Draw File
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
        <div class="lg:col-span-7">
          <div
            class="glass rounded-[2.5rem] overflow-hidden border border-white/5 shadow-2xl h-[500px] flex flex-col"
          >
            <div
              class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]"
            >
              <h2
                class="text-white text-xs font-black uppercase tracking-widest"
              >
                🏆 Leaderboard (Top Accuracy)
              </h2>
              <span class="text-[9px] text-slate-500 uppercase font-bold"
                >Auto-updates every refresh</span
              >
            </div>
            <div class="flex-grow overflow-y-auto custom-scrollbar p-4">
              <table class="w-full text-left">
                <tbody
                  id="leaderboardBody"
                  class="divide-y divide-white/5"
                ></tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div
            class="glass rounded-[2.5rem] overflow-hidden border border-white/5 shadow-2xl h-[500px] flex flex-col"
          >
            <div class="p-8 border-b border-white/5 bg-white/[0.02]">
              <h2
                class="text-white text-xs font-black uppercase tracking-widest"
              >
                📅 Official Answer Sheet
              </h2>
            </div>
            <div class="flex-grow overflow-y-auto custom-scrollbar p-6">
              <div id="answerSheetGrid" class="grid grid-cols-3 gap-3"></div>
            </div>
          </div>
        </div>
      </div>

      <h2
        class="text-white text-sm font-black uppercase tracking-[0.3em] mb-8 flex items-center gap-4"
      >
        <span class="h-[1px] w-12 bg-blue-500"></span> Daily Verified Winners
      </h2>
      <div id="dailyListContainer" class="space-y-4"></div>
    </div>

    <script>
      // Start date for calculations
      const competitionStart = new Date("2026-02-18");

      // Fetch Leaderboard
      async function loadLeaderboard() {
        const res = await fetch("/api/mq/leaderboard");
        const data = await res.json();
        const body = document.getElementById("leaderboardBody");

        if (!Array.isArray(data) || data.length === 0) return;

        body.innerHTML = data
          .map((row, index) => {
            const rank = index + 1;
            // Assign colors for Top 3
            let rankStyle = "text-slate-600";
            let glowStyle = "";
            let crown = "";

            if (rank === 1) {
              rankStyle = "text-yellow-500";
              glowStyle = "bg-yellow-500/10 border-yellow-500/20";
              crown = "👑";
            } else if (rank === 2) {
              rankStyle = "text-slate-300";
              glowStyle = "bg-slate-300/10 border-slate-300/20";
            } else if (rank === 3) {
              rankStyle = "text-amber-600";
              glowStyle = "bg-amber-600/10 border-amber-600/20";
            }

            return `
            <tr class="group hover:bg-white/[0.02] transition-all">
                <td class="p-5 px-8">
                    <div class="flex items-center gap-6">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center font-black text-xl ${rankStyle} ${glowStyle} border border-transparent">
                            ${rank}
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-bold text-lg tracking-wider">${
                              row.msisdn
                            } ${crown}</span>
                        </div>
                    </div>
                </td>
                <td class="p-5 px-8 text-right">
                    <div class="flex flex-col items-end">
                        <span class="text-xl font-black ${
                          rank === 1 ? "text-yellow-500" : "text-emerald-500"
                        }">${row.correct_days}</span>
                        <span class="text-[8px] text-slate-600 font-bold uppercase italic">Correct Days</span>
                    </div>
                </td>
            </tr>
        `;
          })
          .join("");
      }

      // Fetch Answer Key (Displays what you inserted via SQL)
      async function loadAnswerSheet() {
        // We can fetch this from a simple endpoint or just pass the 30 answers if they are static
        const answers = {
          1: "C",
          2: "A",
          3: "C",
          4: "B",
          5: "A",
          6: "C",
          7: "B",
          8: "A",
          9: "B",
          10: "A",
          11: "C",
          12: "A",
          13: "B",
          14: "C",
          15: "A",
          16: "B",
          17: "A",
          18: "C",
          19: "B",
          20: "A",
          21: "B",
          22: "C",
          23: "A",
          24: "B",
          25: "B",
          26: "A",
          27: "B",
          28: "B",
          29: "C",
          30: "A",
        };

        const grid = document.getElementById("answerSheetGrid");
        grid.innerHTML = Object.entries(answers)
          .map(
            ([day, opt]) => `
                <div class="bg-white/5 border border-white/5 rounded-2xl p-4 flex flex-col items-center justify-center group hover:bg-emerald-500/10 hover:border-emerald-500/20 transition-all">
                    <span class="text-[9px] font-black text-slate-500 uppercase mb-1">Day ${day}</span>
                    <span class="text-white font-black text-xl group-hover:text-emerald-500">${opt}</span>
                </div>
            `
          )
          .join("");
      }

      // Fetch Daily Logs
      async function loadDailyList() {
        const res = await fetch("/api/mq/daily-details");
        const data = await res.json();
        const container = document.getElementById("dailyListContainer");

        if (!Array.isArray(data)) return;

        const grouped = data.reduce((acc, obj) => {
          if (!acc[obj.comp_day]) acc[obj.comp_day] = [];
          acc[obj.comp_day].push(obj.msisdn);
          return acc;
        }, {});

        const sortedDays = Object.keys(grouped).sort((a, b) => b - a);

        container.innerHTML = sortedDays
          .map(
            (day) => `
                <div class="glass rounded-[2rem] overflow-hidden transition-all">
                    <button onclick="toggleDay(${day})" class="w-full p-8 flex justify-between items-center hover:bg-white/[0.02] transition-all">
                        <div class="flex items-center gap-6">
                            <div class="h-12 w-12 rounded-2xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20">
                                <span class="text-blue-500 font-black text-sm">${day}</span>
                            </div>
                            <div class="text-left">
                                <span class="text-white font-bold text-sm block">Day ${day} Winners</span>
                                <span class="text-[9px] text-slate-500 font-black uppercase tracking-widest">${getFormattedDate(
                                  day
                                )}</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-6">
                            <span class="text-emerald-500 font-black text-xs uppercase tracking-widest">${
                              grouped[day].length
                            } Correct</span>
                            <svg id="icon-${day}" class="text-slate-700 transition-transform" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </button>
                    <div id="day-content-${day}" class="hidden p-10 pt-2 grid grid-cols-2 md:grid-cols-6 gap-3 bg-black/20 border-t border-white/5">
                        ${grouped[day]
                          .map(
                            (phone) =>
                              `<div class="bg-white/5 p-3 rounded-xl text-center border border-white/5 text-slate-400 font-mono text-[11px]">${phone}</div>`
                          )
                          .join("")}
                    </div>
                </div>
            `
          )
          .join("");
      }

      function getFormattedDate(dayNum) {
        const d = new Date(competitionStart);
        d.setDate(d.getDate() + (parseInt(dayNum) - 1));
        return d.toLocaleDateString("en-GB", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        });
      }

      function toggleDay(day) {
        const el = document.getElementById(`day-content-${day}`);
        const icon = document.getElementById(`icon-${day}`);
        el.classList.toggle("hidden");
        icon.style.transform = el.classList.contains("hidden")
          ? "rotate(0deg)"
          : "rotate(180deg)";
      }

      async function exportToTxt() {
        // Calls the winner-only API
        const res = await fetch("/api/mq/export-winners");
        const data = await res.json();

        if (!Array.isArray(data) || data.length === 0)
          return alert("No winners found.");

        const count = data.length;
        if (
          !confirm(
            `Found ${count} total winners tied for 1st place. Export list?`
          )
        )
          return;

        const content = data.map((row) => row.msisdn).join("\n");
        const blob = new Blob([content], { type: "text/plain" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = `mq_winners_pool_${count}.txt`;
        a.click();
      }

      // Initialize
      loadLeaderboard();
      loadAnswerSheet();
      loadDailyList();
    </script>
  </body>
</html>
