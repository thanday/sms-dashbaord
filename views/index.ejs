<!DOCTYPE html>
<html>
  <head>
    <title>SMS Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet" />
    <style>
      body { font-family: "Plus Jakarta Sans", sans-serif; }
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
      @keyframes pulse-soft { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
      .anim-pulse { animation: pulse-soft 2s infinite; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-300 p-8">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
      <div class="space-y-8">
        <h1 class="text-3xl font-black text-white italic tracking-tighter">MANAGEMENT</h1>

        <div class="bg-slate-900 p-6 rounded-3xl border border-slate-800 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-blue-500 mb-4">1. Programs</h2>
          <div class="flex gap-2 mb-6">
            <input type="text" id="progName" placeholder="Program Name" class="bg-slate-800 border-none rounded-xl px-4 py-2 w-full text-white outline-none focus:ring-2 focus:ring-blue-500 transition-all" />
            <button onclick="saveProgram()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-xl font-bold transition-all">Add</button>
          </div>
          <div id="programList" class="space-y-2 max-h-60 overflow-y-auto pr-2 custom-scrollbar"></div>
        </div>

        <div class="bg-slate-900 p-6 rounded-3xl border border-slate-800 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-purple-500 mb-4">2. Keywords & Timing</h2>
          <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Select Program</label>
          <select id="progSelectSetup" onchange="loadKeywordsForProgram()" class="bg-slate-800 w-full rounded-xl px-4 py-2 mb-4 outline-none text-white cursor-pointer"></select>

          <div class="grid grid-cols-2 gap-2 mb-4">
            <div>
              <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">SMS Code</label>
              <input type="text" id="keyName" placeholder="e.g. AA" class="bg-slate-800 border-none rounded-xl px-4 py-2 w-full text-white outline-none focus:ring-2 focus:ring-purple-500" />
            </div>
            <div>
              <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Active Time</label>
              <input type="text" id="activeTime" placeholder="e.g. 13:00 - 14:00" class="bg-slate-800 border-none rounded-xl px-4 py-2 w-full text-white outline-none focus:ring-2 focus:ring-purple-500" />
            </div>
          </div>
          <button onclick="saveKeyword()" class="w-full bg-purple-600 hover:bg-purple-500 text-white px-6 py-3 rounded-xl font-bold transition-all mb-6">Add Keyword to Program</button>
          <div id="keywordList" class="space-y-2 max-h-60 overflow-y-auto pr-2 text-sm custom-scrollbar"></div>
        </div>
      </div>

      <div class="bg-slate-900 p-8 rounded-[2.5rem] border border-slate-800 h-fit sticky top-8 shadow-2xl">
        <h2 class="text-sm font-bold uppercase tracking-widest text-emerald-500 mb-6">3. Sync Data</h2>

        <div id="statusContainer" class="hidden mb-8 p-4 bg-black/40 border border-slate-800 rounded-2xl">
            <div class="flex justify-between items-end mb-2">
                <span id="statusText" class="text-[10px] font-black uppercase tracking-widest text-blue-400 anim-pulse">Initializing...</span>
                <span id="statusPercent" class="text-xl font-black text-white">0%</span>
            </div>
            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                <div id="statusBar" class="bg-blue-500 h-full transition-all duration-500 w-0"></div>
            </div>
        </div>

        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase">Target Program</label>
        <select id="progSelectImport" onchange="updateKeywordDropdown()" class="bg-slate-800 w-full rounded-xl px-4 py-3 mb-4 text-white border-none cursor-pointer"></select>

        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase">Specific Keyword</label>
        <select id="keySelectImport" class="bg-slate-800 w-full rounded-xl px-4 py-3 mb-6 text-white border-none cursor-pointer"></select>

        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase">Operator Source (CSV)</label>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <button onclick="setOp('Ooredoo')" id="btn-Ooredoo" class="op-btn bg-slate-800 py-3 rounded-xl font-bold border-2 border-transparent transition-all">Ooredoo</button>
          <button onclick="setOp('Dhiraagu')" id="btn-Dhiraagu" class="op-btn bg-slate-800 py-3 rounded-xl font-bold border-2 border-transparent transition-all">Dhiraagu</button>
        </div>

        <input type="file" id="csvFile" class="hidden" onchange="handleUpload()" />
        <button onclick="document.getElementById('csvFile').click()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-4 rounded-2xl font-black text-lg transition-all mb-8 shadow-lg active:scale-95">SELECT & SYNC CSV</button>

        <div class="space-y-4 pt-4 border-t border-slate-800">
            <button id="ooredooSyncBtn" onclick="syncOperator('ooredoo')" class="w-full bg-rose-600 hover:bg-rose-500 text-white py-4 rounded-2xl font-black text-lg transition-all shadow-lg active:scale-95 flex items-center justify-center gap-3">
                <span id="ooredooIcon">🔄</span> 
                <span id="ooredooBtnText">SYNC OOREDOO PORTAL</span>
            </button>

            <button id="dhiraaguSyncBtn" onclick="syncOperator('dhiraagu')" class="w-full bg-[#e31e24] hover:bg-red-500 text-white py-4 rounded-2xl font-black text-lg transition-all shadow-lg active:scale-95 flex items-center justify-center gap-3">
                <span id="dhiraaguIcon">🔄</span> 
                <span id="dhiraaguBtnText">SYNC DHIRAAGU PORTAL</span>
            </button>
        </div>

        <p class="text-[10px] text-slate-600 mt-4 text-center font-bold italic">Note: Live portal sync may take a few minutes.</p>
      </div>
    </div>

    <script>
      let selectedOp = "Ooredoo";
      const socket = io();

      // --- 1. PORTAL SYNC SOCKET LISTENER ---
      socket.on('statusUpdate', (data) => {
          const container = document.getElementById('statusContainer');
          const bar = document.getElementById('statusBar');
          const text = document.getElementById('statusText');
          const percentText = document.getElementById('statusPercent');
          
          container.classList.remove('hidden');
          bar.style.width = data.percent + '%';
          percentText.innerText = data.percent + '%';
          text.innerText = data.status;

          if (data.done) {
              setTimeout(() => {
                  container.classList.add('hidden');
                  // Reset all buttons to original state
                  resetSyncButtons();
                  alert(data.status);
                  location.reload(); 
              }, 2000);
          }
      });

      function resetSyncButtons() {
        ['ooredoo', 'dhiraagu'].forEach(op => {
            const btn = document.getElementById(`${op}SyncBtn`);
            const btnText = document.getElementById(`${op}BtnText`);
            btn.disabled = false;
            btn.classList.remove('opacity-50', 'cursor-not-allowed');
            btnText.innerText = `SYNC ${op.toUpperCase()} PORTAL`;
        });
      }

      function setOp(op) {
        selectedOp = op;
        document.querySelectorAll(".op-btn").forEach((b) => b.classList.remove("border-blue-500", "bg-slate-700", "text-white"));
        const activeBtn = document.getElementById("btn-" + op);
        activeBtn.classList.add("border-blue-500", "bg-slate-700", "text-white");
      }

      // --- 2. AUTOMATED PORTAL SYNC TRIGGER ---
      async function syncOperator(operator) {
        const btn = document.getElementById(`${operator}SyncBtn`);
        const btnText = document.getElementById(`${operator}BtnText`);
        
        // Disable both buttons during any active sync to prevent conflicts
        ['ooredoo', 'dhiraagu'].forEach(op => {
            document.getElementById(`${op}SyncBtn`).disabled = true;
            document.getElementById(`${op}SyncBtn`).classList.add('opacity-50', 'cursor-not-allowed');
        });

        btnText.innerText = "SCRAPING IN PROGRESS...";
        
        try {
            const res = await fetch(`/api/sync-${operator}`, { method: "POST" });
            if (!res.ok) throw new Error("Could not start sync process");
        } catch (err) {
            alert("Error: " + err.message);
            resetSyncButtons();
        }
      }

      // --- 3. CORE MANAGEMENT FUNCTIONS ---
      async function init() {
        const res = await fetch("/api/programs");
        const progs = await res.json();
        const dropdowns = [document.getElementById("progSelectSetup"), document.getElementById("progSelectImport")];
        dropdowns.forEach((d) => { d.innerHTML = progs.map((p) => `<option value="${p.id}">${p.name}</option>`).join(""); });
        const progList = document.getElementById("programList");
        progList.innerHTML = progs.map((p) => `
            <div class="flex justify-between items-center bg-slate-800/50 p-3 rounded-xl border border-slate-800 group transition-all hover:bg-slate-800">
                <span class="font-bold text-slate-200">${p.name}</span>
                <button onclick="deleteProgram(${p.id})" class="text-rose-500 opacity-0 group-hover:opacity-100 p-2 hover:bg-rose-500/10 rounded-lg transition-all text-xs font-bold">DELETE</button>
            </div>
        `).join("");
        loadKeywordsForProgram();
        updateKeywordDropdown();
      }

      async function saveProgram() {
        const name = document.getElementById("progName").value.trim();
        if (!name) return;
        await fetch("/api/programs", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name }) });
        document.getElementById("progName").value = "";
        init();
      }

      async function deleteProgram(id) {
        if (confirm("Delete program and all associated data?")) {
          await fetch(`/api/programs/${id}`, { method: "DELETE" });
          init();
        }
      }


      async function editKeyword(id, currentName, currentTime) {
    const newName = prompt("Edit SMS Code:", currentName);
    if (newName === null) return; // Cancelled

    const newTime = prompt("Edit Active Time (e.g. 13:00 - 14:00):", currentTime);
    if (newTime === null) return; // Cancelled

    try {
        const response = await fetch(`/api/keywords/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name: newName, active_time: newTime })
        });

        if (response.ok) {
            loadKeywordsForProgram();
            updateKeywordDropdown();
        } else {
            alert("Failed to update keyword.");
        }
    } catch (err) {
        alert("Error updating keyword.");
    }
}

      async function loadKeywordsForProgram() {
    const progId = document.getElementById("progSelectSetup").value;
    if (!progId) return;
    const res = await fetch(`/api/keywords/${progId}`);
    const keys = await res.json();
    const keyList = document.getElementById("keywordList");
    keyList.innerHTML = keys.map((k) => `
        <div class="flex justify-between items-center p-3 bg-slate-800/30 rounded-xl mb-1 border border-slate-800/50 group">
            <div class="flex flex-col">
                <span class="text-white font-bold tracking-wider">${k.name}</span>
                <span class="text-[10px] text-slate-500 font-bold uppercase">${k.active_time || "No active time set"}</span>
            </div>
            <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-all">
                <button onclick="editKeyword(${k.id}, '${k.name}', '${k.active_time || ''}')" class="text-[10px] text-blue-400 font-bold hover:underline">EDIT</button>
                <button onclick="deleteKeyword(${k.id})" class="text-[10px] text-rose-400 font-bold hover:underline">REMOVE</button>
            </div>
        </div>
    `).join("");
}

      async function saveKeyword() {
        const name = document.getElementById("keyName").value.trim();
        const active_time = document.getElementById("activeTime").value.trim();
        const program_id = document.getElementById("progSelectSetup").value;
        if (!name || !program_id) return alert("Enter keyword.");
        const response = await fetch("/api/keywords", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name, program_id, active_time }) });
        if (response.ok) {
          document.getElementById("keyName").value = "";
          document.getElementById("activeTime").value = "";
          loadKeywordsForProgram();
          updateKeywordDropdown();
        }
      }

      async function deleteKeyword(id) {
        if (confirm("Remove keyword?")) {
          await fetch(`/api/keywords/${id}`, { method: "DELETE" });
          loadKeywordsForProgram();
          updateKeywordDropdown();
        }
      }

      async function updateKeywordDropdown() {
        const progId = document.getElementById("progSelectImport").value;
        if (!progId) return;
        const res = await fetch(`/api/keywords/${progId}`);
        const keys = await res.json();
        document.getElementById("keySelectImport").innerHTML = keys.map((k) => `<option value="${k.id}">${k.name} ${k.active_time ? "(" + k.active_time + ")" : ""}</option>`).join("");
      }

      async function handleUpload() {
        const fileInput = document.getElementById("csvFile");
        const file = fileInput.files[0];
        const keyword_id = document.getElementById("keySelectImport").value;
        if (!file || !keyword_id) return alert("Select file & keyword.");
        const formData = new FormData();
        formData.append("file", file);
        formData.append("operator", selectedOp);
        formData.append("keyword_id", keyword_id);
        const btn = document.querySelector('button[onclick*="csvFile"]');
        btn.innerText = "SYNCING..."; btn.disabled = true;
        try {
          const res = await fetch("/upload", { method: "POST", body: formData });
          if (res.ok) { alert("Sync Successful!"); fileInput.value = ""; }
        } catch (e) { alert("Connection error."); }
        finally { btn.innerText = "SELECT & SYNC CSV"; btn.disabled = false; }
      }

      setOp("Ooredoo");
      window.onload = init;
    </script>
  </body>
</html>