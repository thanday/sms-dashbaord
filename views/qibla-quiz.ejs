<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qibla Quiz | SSTV Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #02040a; color: #94a3b8; }
        .glass { background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.03); }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        .gold-glow { box-shadow: 0 0 40px rgba(251, 191, 36, 0.05); }
    </style>
</head>
<body class="p-6 md:p-12">
    <div class="max-w-7xl mx-auto">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
            <div>
                <div class="flex items-center gap-4">
                    <h1 class="text-5xl font-black text-white tracking-tighter uppercase italic leading-none">Qibla Quiz</h1>

                </div>
                <p class="text-amber-500 font-bold text-[10px] uppercase tracking-[0.4em] mt-3 flex items-center gap-2">
                    <span class="w-8 h-[1px] bg-amber-500"></span> 30 Days Ramadan Analytics (Keyword: QQ)
                </p>
                
            </div>
            
            <div class="flex gap-4">
                <button onclick="exportToTxt()" class="bg-amber-500 hover:bg-amber-400 px-6 py-3 rounded-2xl text-black text-[10px] font-black uppercase tracking-widest transition-all shadow-lg shadow-amber-500/10">
                    Export Draw File
                </button>
            </div>
            <div id="winnerBadge" class="hidden bg-amber-500/10 border border-amber-500/30 px-4 py-1.5 rounded-full animate-pulse">
                <span id="winnerCount" class="text-amber-500 text-[10px] font-black uppercase tracking-[0.2em]">0 Winners Tied</span>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
            
            <div class="lg:col-span-7">
                <div class="glass rounded-[2.5rem] overflow-hidden border border-white/5 shadow-2xl h-[550px] flex flex-col gold-glow">
                  
                    <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
                        <h2 class="text-white text-xs font-black uppercase tracking-widest">🏆 Leaderboard</h2>
                        <input type="text" id="qqSearch" onkeyup="filterQQTable()" placeholder="Search Number..." class="bg-white/5 border border-white/10 rounded-lg px-3 py-1 text-[10px] text-white focus:outline-none focus:border-amber-500/50">
                        <span class="text-[9px] text-slate-500 uppercase font-bold">Live Standings</span>
                    </div>
                    <div class="flex-grow overflow-y-auto custom-scrollbar p-4">
                        <table class="w-full text-left">
                            <tbody id="qiblaTableBody" class="divide-y divide-white/5">
                                </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-5">
                <div class="glass rounded-[2.5rem] overflow-hidden border border-white/5 shadow-2xl h-[550px] flex flex-col">
                    <div class="p-8 border-b border-white/5 bg-white/[0.02]">
                        <h2 class="text-white text-xs font-black uppercase tracking-widest">📅 Official QQ Answers</h2>
                    </div>
                    <div class="flex-grow overflow-y-auto custom-scrollbar p-6">
                        <div id="qiblaAnswerGrid" class="grid grid-cols-3 gap-3">
                            </div>
                    </div>
                </div>
            </div>

        </div>

        <h2 class="text-white text-sm font-black uppercase tracking-[0.3em] mb-8 flex items-center gap-4">
            <span class="h-[1px] w-12 bg-amber-500"></span> Daily Verified Winners
        </h2>
        
        <div id="dailyListContainer" class="space-y-4">
            </div>
    </div>

    <script>
        const competitionStart = new Date('2026-02-18');
        const qiblaAnswers = {
            1: 'C', 2: 'A', 3: 'C', 4: 'B', 5: 'B', 6: 'B', 7: 'A', 8: 'A', 9: 'A', 10: 'A',
            11: 'A', 12: 'A', 13: 'A', 14: 'C', 15: 'B', 16: 'A', 17: 'B', 18: 'B', 19: 'B', 20: 'B',
            21: 'A', 22: 'A', 23: 'C', 24: 'A', 25: 'A', 26: 'C', 27: 'B', 28: 'A', 29: 'A', 30: 'A'
        };

        async function init() {
            await Promise.all([
                loadLeaderboard(),
                loadDailyList()
            ]);
            renderAnswerSheet();
        }

        async function loadLeaderboard() {
    const res = await fetch('/api/qibla/leaderboard');
    const data = await res.json();
    const body = document.getElementById('qiblaTableBody');
    const badge = document.getElementById('winnerBadge');
    const countDisplay = document.getElementById('winnerCount');
    
    if (!data || !data.length) {
        body.innerHTML = '<tr><td class="p-12 text-center text-slate-600 italic">No entries found.</td></tr>';
        return;
    }

    
    // Identify the highest score currently in the list
    const topScore = data[0].correct_days;
    // Count how many people actually have that score
    const winnersCount = data.filter(row => row.correct_days === topScore).length;

    // Update the Pulsing Badge with the TRUE count
    if (topScore > 0) {
        badge.classList.remove('hidden');
        countDisplay.innerText = `${winnersCount} PEOPLE TIED FOR #1`;
    }

    body.innerHTML = data.map((row, index) => {
        const isTiedForFirst = row.correct_days === topScore;
        
        // If they are in the winning pool, show '1', otherwise show their actual position
        const displayRank = isTiedForFirst ? 1 : (index + 1);
        const rankColor = isTiedForFirst ? "text-amber-500 font-black" : "text-slate-700";

        return `
            <tr class="group hover:bg-white/[0.02] transition-all">
                <td class="p-6 px-8 flex items-center gap-6">
                    <span class="text-2xl ${rankColor} w-8">${displayRank}</span>
                    <div class="flex flex-col">
                        <span class="text-white font-bold text-lg tracking-wider">
                            ${row.msisdn} ${isTiedForFirst ? '👑' : ''}
                        </span>
                        <span class="text-[9px] text-slate-500 uppercase font-black tracking-widest">
                            ${isTiedForFirst ? 'Winner Pool' : 'Participant'}
                        </span>
                    </div>
                </td>
                <td class="p-6 px-8 text-right">
                    <span class="text-amber-500 font-black text-xl">${row.correct_days}</span>
                    <span class="text-[8px] text-slate-600 font-bold uppercase block tracking-tighter">Correct Days</span>
                </td>
            </tr>
        `;
    }).join('');
}

        function renderAnswerSheet() {
            const grid = document.getElementById('qiblaAnswerGrid');
            grid.innerHTML = Object.entries(qiblaAnswers).map(([day, opt]) => `
                <div class="bg-white/5 border border-white/5 rounded-2xl p-4 flex flex-col items-center justify-center group hover:border-amber-500/30 transition-all">
                    <span class="text-[9px] font-black text-slate-500 uppercase mb-1">Day ${day}</span>
                    <span class="text-white font-black text-xl group-hover:text-amber-500">${opt}</span>
                </div>
            `).join('');
        }

        async function loadDailyList() {
            const res = await fetch('/api/qibla/daily-details');
            const data = await res.json();
            const container = document.getElementById('dailyListContainer');

            if (!container || !data || !data.length) return;

            const grouped = data.reduce((acc, obj) => {
                if (!acc[obj.comp_day]) acc[obj.comp_day] = [];
                acc[obj.comp_day].push(obj.msisdn);
                return acc;
            }, {});

            container.innerHTML = Object.keys(grouped).sort((a,b) => b-a).map(day => `
                <div class="glass rounded-[2rem] overflow-hidden">
                    <button onclick="toggleDay(${day})" class="w-full p-8 flex justify-between items-center hover:bg-white/[0.02] transition-all">
                        <div class="flex items-center gap-6">
                            <div class="h-12 w-12 rounded-2xl bg-amber-500/10 flex items-center justify-center border border-amber-500/20 text-amber-500 font-black text-sm">${day}</div>
                            <div class="text-left">
                                <span class="text-white font-bold text-sm block">Day ${day} Winners</span>
                                <span class="text-[9px] text-slate-500 font-black uppercase tracking-widest">${getFormattedDate(day)}</span>
                            </div>
                        </div>
                        <span class="text-amber-500 font-black text-xs uppercase">${grouped[day].length} CORRECT</span>
                    </button>
                    <div id="day-content-${day}" class="hidden p-10 pt-2 grid grid-cols-2 md:grid-cols-6 gap-3 bg-black/20 border-t border-white/5">
                        ${grouped[day].map(num => `<div class="bg-white/5 p-3 rounded-xl text-center border border-white/5 text-slate-400 font-mono text-[11px]">${num}</div>`).join('')}
                    </div>
                </div>
            `).join('');
        }

        function getFormattedDate(dayNum) {
            const d = new Date(competitionStart);
            d.setDate(d.getDate() + (parseInt(dayNum) - 1));
            return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
        }

        function toggleDay(day) {
            const el = document.getElementById(`day-content-${day}`);
            if(el) el.classList.toggle('hidden');
        }

        async function exportToTxt() {
            const res = await fetch('/api/qibla/export-winners');
            const data = await res.json();
            if(!data || !data.length) return alert("No winners found.");
            
            const content = data.map(row => row.msisdn).join('\n');
            const blob = new Blob([content], { type: 'text/plain' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `qibla_draw_pool_export.txt`;
            a.click();
        }
        function filterQQTable() {
        const input = document.getElementById("qqSearch").value.toUpperCase();
        const body = document.getElementById("qiblaTableBody");
        const rows = body.getElementsByTagName("tr");

        for (let i = 0; i < rows.length; i++) {
            // This looks at the phone number text in each row
            const text = rows[i].textContent || rows[i].innerText;
            if (text.toUpperCase().indexOf(input) > -1) {
                rows[i].style.display = "";
            } else {
                rows[i].style.display = "none";
            }
        }
    }
        init();
    </script>
</body>
</html>