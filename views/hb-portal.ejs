<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hadhiyaa Badhiyaa | SSTV Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #0a0205; color: #94a3b8; }
        .glass { background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .gift-card { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .gift-card:hover { transform: translateY(-10px); border-color: rgba(236, 72, 153, 0.3); background: rgba(236, 72, 153, 0.03); }
    </style>
</head>
<body class="p-6 md:p-12">
    <div class="max-w-7xl mx-auto">
        
        <div class="flex justify-between items-end mb-16">
            <div>
                <h1 class="text-7xl font-black text-white tracking-tighter uppercase italic leading-none">Hadhiyaa <span class="text-pink-500">Badhiyaa</span></h1>
                <p class="text-slate-500 font-bold text-[10px] uppercase tracking-[0.5em] mt-4 flex items-center gap-3">
                    <span class="w-12 h-[1px] bg-pink-500"></span> Eid Giveaway (Keyword: HB)
                </p>
            </div>
            <div class="hidden md:block text-right">
                <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest block mb-1">Last Data Sync</span>
                <span class="text-white font-bold text-sm" id="syncTime">Manual Refresh Required</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div class="glass gift-card rounded-[3rem] p-10 flex flex-col items-center text-center">
                <div class="w-20 h-20 bg-pink-500/10 rounded-3xl flex items-center justify-center mb-8 border border-pink-500/20">
                    <span class="text-3xl">✨</span>
                </div>
                <h3 class="text-white font-black text-2xl uppercase tracking-tighter">ESSENZA</h3>
                <p class="text-pink-500 text-[10px] font-black uppercase tracking-widest mb-8">Perfume Pack</p>
                <div class="text-6xl font-black text-white mb-10 tabular-nums" id="count-essenza">0</div>
                <button onclick="exportHB('essenza')" class="w-full bg-pink-600 hover:bg-pink-500 text-white py-5 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em] transition-all">Export Draw</button>
            </div>

            <div class="glass gift-card rounded-[3rem] p-10 flex flex-col items-center text-center">
                <div class="w-20 h-20 bg-blue-500/10 rounded-3xl flex items-center justify-center mb-8 border border-blue-500/20">
                    <span class="text-3xl">🚲</span>
                </div>
                <h3 class="text-white font-black text-2xl uppercase tracking-tighter">Skip n Smile</h3>
                <p class="text-blue-400 text-[10px] font-black uppercase tracking-widest mb-8">Bicycle Pack</p>
                <div class="text-6xl font-black text-white mb-10 tabular-nums" id="count-skip">0</div>
                <button onclick="exportHB('skip')" class="w-full bg-blue-600 hover:bg-blue-500 text-white py-5 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em] transition-all">Export Draw</button>
            </div>

            <div class="glass gift-card rounded-[3rem] p-10 flex flex-col items-center text-center">
                <div class="w-20 h-20 bg-amber-500/10 rounded-3xl flex items-center justify-center mb-8 border border-amber-500/20">
                    <span class="text-3xl">🎣</span>
                </div>
                <h3 class="text-white font-black text-2xl uppercase tracking-tighter">BK</h3>
                <p class="text-amber-500 text-[10px] font-black uppercase tracking-widest mb-8">Fishing Rod Pack</p>
                <div class="text-6xl font-black text-white mb-10 tabular-nums" id="count-bk">0</div>
                <button onclick="exportHB('bk')" class="w-full bg-amber-600 hover:bg-amber-500 text-black py-5 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em] transition-all">Export Draw</button>
            </div>
        </div>

        <div class="glass rounded-[3rem] p-10">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
                <div>
                    <h2 class="text-white text-lg font-black uppercase tracking-tighter italic">Daily Trends</h2>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Participation volume by category</p>
                </div>
                <div class="flex gap-6">
                    <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-pink-500"></span><span class="text-[9px] text-slate-400 font-black uppercase">Essenza</span></div>
                    <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-blue-500"></span><span class="text-[9px] text-slate-400 font-black uppercase">Skip n Smile</span></div>
                    <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-amber-500"></span><span class="text-[9px] text-slate-400 font-black uppercase">BK</span></div>
                </div>
            </div>
            <div class="h-[350px] w-full">
                <canvas id="hbDailyChart"></canvas>
            </div>
        </div>

    </div>

    <script>
        async function loadHBPortal() {
            try {
                // 1. Fetch Summary Stats
                const statsRes = await fetch('/api/hb/stats');
                const stats = await statsRes.json();
                document.getElementById('count-essenza').innerText = stats.essenza_count;
                document.getElementById('count-skip').innerText = stats.skip_count;
                document.getElementById('count-bk').innerText = stats.bk_count;
                document.getElementById('syncTime').innerText = new Date().toLocaleTimeString();

                // 2. Fetch Chart Data
                const chartRes = await fetch('/api/hb/chart-data');
                const chartData = await chartRes.json();
                renderChart(chartData);
            } catch (err) { console.error("Error loading HB Portal:", err); }
        }

        function renderChart(data) {
            const ctx = document.getElementById('hbDailyChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(d => new Date(d.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' })),
                    datasets: [
                        {
                            label: 'Essenza',
                            data: data.map(d => d.essenza),
                            borderColor: '#ec4899',
                            backgroundColor: 'rgba(236, 72, 153, 0.05)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointBackgroundColor: '#ec4899'
                        },
                        {
                            label: 'Skip n Smile',
                            data: data.map(d => d.skip),
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.05)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointBackgroundColor: '#3b82f6'
                        },
                        {
                            label: 'BK',
                            data: data.map(d => d.bk),
                            borderColor: '#fbbf24',
                            backgroundColor: 'rgba(251, 191, 36, 0.05)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointBackgroundColor: '#fbbf24'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.05)', drawBorder: false },
                            ticks: { color: '#64748b', font: { size: 10, weight: 'bold' } }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { size: 10, weight: 'bold' } }
                        }
                    }
                }
            });
        }

        async function exportHB(cat) {
            const res = await fetch(`/api/hb/export/${cat}`);
            const data = await res.json();
            if(!data.length) return alert("No entries found.");
            
            const content = data.map(r => r.msisdn).join('\n');
            const blob = new Blob([content], { type: 'text/plain' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `hb_${cat}_draw_${new Date().toISOString().split('T')[0]}.txt`;
            a.click();
        }

        // Run once on load
        loadHBPortal();
    </script>
</body>
</html>